void setup()
{
  lcd.begin (16,2);//Identifica que o display possui 16 colunas e 2 linhas
  lcd.setBacklight(HIGH);//Liga a luz de fundo
  lcd.setCursor(0,0);//Marca o cursor na posição coluna 0, linha 0
  lcd.print("A- Abrir o cofre");//Escreve a mensagem a partir da posição coluna 0, linha 0
  lcd.setCursor(0,1);
  lcd.print("B- Alterar senha");
  //Todos os fios das linhas do teclado são definidos como saídas
  pinMode(linha1,OUTPUT);
  pinMode(linha2,OUTPUT);
  pinMode(linha3,OUTPUT);
  pinMode(linha4,OUTPUT);
  //Todos os fios das colunas do teclado são definidos como entradas
  pinMode(coluna1,INPUT);
  pinMode(coluna2,INPUT);
  pinMode(coluna3,INPUT);
  pinMode(coluna4,INPUT);
  // Define o pino 12 do Arduino para controlar o servo motor
  servoTrancaCofre.attach(12);
  servoTrancaCofre.write(0); // Inicia o servo na posição 0°
  // Define o pino de fim de curso como entrada
  pinMode(fimDeCurso,INPUT);
}
 
